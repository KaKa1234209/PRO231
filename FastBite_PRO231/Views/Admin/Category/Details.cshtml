@model Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Chi tiết danh mục</h1>
                <p>Xem thông tin chi tiết của danh mục.</p>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mã danh mục</div>
                <div class="fb-detail-value">#@Model.CategoryId</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Tên danh mục</div>
                <div class="fb-detail-value">@Model.CategoryName</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mô tả</div>
                <div class="fb-detail-value">
                    @(string.IsNullOrWhiteSpace(Model.Description)
                        ? "Chưa có mô tả"
                        : Model.Description)
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-center mt-4">
                <a class="btn fb-btn-primary"
                   asp-controller="Categories"
                   asp-action="Edit"
                   asp-route-categoryid="@Model.CategoryId">
                    Sửa
                </a>

                <a class="btn fb-btn-outline" asp-controller="Categories" asp-action="Index">
                    Quay lại
                </a>
            </div>
        </div>
    </div>
</section>