@model FastBite_PRO231.ViewModels.EmployeeManagementFormViewModel

@{
    ViewData["Title"] = "Chỉnh sửa nhân viên";
}

<section class="fbemployee-page">
    <div class="fbemployee-header">
        <div>
            <p>CHỈNH SỬA NHÂN VIÊN</p>

            <h1>@Model.FullName</h1>

            <span>
                Cập nhật hồ sơ, trạng thái làm việc và mật khẩu.
            </span>
        </div>

        <a asp-controller="Employees"
           asp-action="Details"
           asp-route-id="@Model.EmployeeId"
           class="fbemployee-reset-button">

            ← Quay lại chi tiết
        </a>
    </div>

    <div class="fbemployee-form-grid">
        <section class="fbemployee-form-card">
            <div class="fbemployee-panel-heading">
                <div>
                    <p>THÔNG TIN NHÂN VIÊN</p>
                    <h2>Cập nhật hồ sơ</h2>
                </div>
            </div>

            <form asp-controller="Employees"
                  asp-action="Edit"
                  asp-route-id="@Model.EmployeeId"
                  method="post">

                @Html.AntiForgeryToken()

                <input asp-for="EmployeeId"
                       type="hidden" />

                <input asp-for="UserId"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="FullName"
                               class="form-control" />

                        <span asp-validation-for="FullName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UserName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="UserName"
                               class="form-control" />

                        <span asp-validation-for="UserName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Email"
                               type="email"
                               class="form-control" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Phone"
                               class="form-control" />

                        <span asp-validation-for="Phone"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Position"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Position"
                               class="form-control" />

                        <span asp-validation-for="Position"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="HireDate"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="HireDate"
                               type="date"
                               class="form-control"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />

                        <span asp-validation-for="HireDate"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Status"
                               class="form-label fw-bold">
                        </label>

                        <select asp-for="Status"
                                class="form-select">

                            @if (Model.Status == "Đang làm việc")
                            {
                                <option value="Đang làm việc" selected>
                                    Đang làm việc
                                </option>
                            }
                            else
                            {
                                <option value="Đang làm việc">
                                    Đang làm việc
                                </option>
                            }

                            @if (Model.Status == "Đã nghỉ việc")
                            {
                                <option value="Đã nghỉ việc" selected>
                                    Đã nghỉ việc
                                </option>
                            }
                            else
                            {
                                <option value="Đã nghỉ việc">
                                    Đã nghỉ việc
                                </option>
                            }
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password"
                               class="form-label fw-bold">

                            Mật khẩu mới
                        </label>

                        <div class="fbemployee-password-wrap">
                            <input asp-for="Password"
                                   class="form-control"
                                   id="employeePassword"
                                   autocomplete="new-password"
                                   placeholder="Để trống nếu không đổi" />

                            <button type="button"
                                    class="fbemployee-show-password"
                                    data-target="employeePassword">

                                Hiện
                            </button>
                        </div>

                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword"
                               class="form-label fw-bold">

                            Xác nhận mật khẩu mới
                        </label>

                        <div class="fbemployee-password-wrap">
                            <input asp-for="ConfirmPassword"
                                   class="form-control"
                                   id="employeeConfirmPassword"
                                   autocomplete="new-password"
                                   placeholder="Nhập lại mật khẩu mới" />

                            <button type="button"
                                    class="fbemployee-show-password"
                                    data-target="employeeConfirmPassword">

                                Hiện
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger">
                        </span>
                    </div>
                </div>

                <div class="fbemployee-warning">
                    Để trống hai ô mật khẩu nếu không muốn đổi mật khẩu.
                    Chuyển sang “Đã nghỉ việc” sẽ khóa tài khoản.
                </div>

                <div class="fbemployee-form-actions">
                    <button type="submit"
                            class="fbemployee-save-button"
                            onclick="return confirm('Xác nhận lưu thay đổi nhân viên?')">

                        Lưu thay đổi
                    </button>

                    <a asp-controller="Users"
                       asp-action="ResetPassword"
                       asp-route-id="@Model.UserId"
                       class="fbemployee-password-button">

                        Đặt lại mật khẩu
                    </a>

                    <a asp-controller="Employees"
                       asp-action="Details"
                       asp-route-id="@Model.EmployeeId"
                       class="fbemployee-reset-button">

                        Hủy
                    </a>
                </div>
            </form>
        </section>

        <aside class="fbemployee-guide-card">
            <div class="fbemployee-guide-icon">
                👤
            </div>

            <h2>@Model.FullName</h2>

            <div class="fbemployee-guide-row">
                <span>Mã nhân viên</span>

                <strong>
                    #@Model.EmployeeId
                </strong>
            </div>

            <div class="fbemployee-guide-row">
                <span>Mã tài khoản</span>

                <strong>
                    #@Model.UserId
                </strong>
            </div>

            <div class="fbemployee-guide-row">
                <span>Tên đăng nhập</span>

                <strong>
                    @("@")@Model.UserName
                </strong>
            </div>

            <div class="fbemployee-guide-row">
                <span>Trạng thái</span>

                <strong>
                    @Model.Status
                </strong>
            </div>

            <p>
                Không xóa hồ sơ nhân viên đã xử lý đơn hoặc hóa đơn
                để bảo toàn lịch sử hoạt động.
            </p>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const buttons =
                document.querySelectorAll(
                    ".fbemployee-show-password");

            buttons.forEach(function (button) {
                button.addEventListener("click", function () {
                    const input =
                        document.getElementById(
                            button.dataset.target);

                    if (!input) {
                        return;
                    }

                    const isPassword =
                        input.type === "password";

                    input.type =
                        isPassword ? "text" : "password";

                    button.textContent =
                        isPassword ? "Ẩn" : "Hiện";
                });
            });
        });
    </script>
}