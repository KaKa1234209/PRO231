@model FastBite_PRO231.Models.EmployeeCreateVM

@{
    ViewData["Title"] = "Xóa nhân viên";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Xóa nhân viên</h1>
                <p>Bạn có chắc chắn muốn xóa nhân viên này không?</p>
            </div>

            <div class="alert alert-danger fb-alert">
                Lưu ý: nhân viên đã phát sinh đơn hàng hoặc hóa đơn sẽ không thể xóa, hệ thống chỉ chuyển sang trạng thái đã nghỉ việc.
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mã nhân viên</div>
                <div class="fb-detail-value">#@Model.EmployeeId</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Họ tên</div>
                <div class="fb-detail-value">@Model.FullName</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Tên đăng nhập</div>
                <div class="fb-detail-value">@Model.UserName</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Chức vụ</div>
                <div class="fb-detail-value">@Model.Position</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Trạng thái</div>
                <div class="fb-detail-value">@Model.Status</div>
            </div>

            <form asp-controller="Employees"
                  asp-action="Delete"
                  asp-route-employeeid="@Model.EmployeeId"
                  method="post"
                  class="d-flex gap-2 justify-content-center mt-4">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn fb-btn-danger">
                    Xác nhận xóa
                </button>

                <a class="btn fb-btn-outline" asp-controller="Employees" asp-action="Index">
                    Hủy
                </a>
            </form>
        </div>
    </div>
</section>