@model Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Chi tiết sản phẩm</h1>
                <p>Xem thông tin chi tiết sản phẩm.</p>
            </div>

            <div class="text-center mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.Image))
                {
                    <img src="@Model.Image"
                         class="fb-product-thumb"
                         style="width: 130px; height: 130px;"
                         alt="@Model.ProductName" />
                }
                else
                {
                    <div class="fb-product-placeholder mx-auto"
                         style="width: 130px; height: 130px; font-size: 60px;">
                        🍔
                    </div>
                }
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mã sản phẩm</div>
                <div class="fb-detail-value">#@Model.ProductId</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Tên sản phẩm</div>
                <div class="fb-detail-value">@Model.ProductName</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Danh mục</div>
                <div class="fb-detail-value">
                    @(Model.Category == null
                        ? "Chưa có danh mục"
                        : Model.Category.CategoryName)
                </div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Giá bán</div>
                <div class="fb-detail-value fb-price">
                    @String.Format("{0:N0}đ", Model.Price)
                </div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Trạng thái</div>
                <div class="fb-detail-value">
                    @if (Model.Status)
                    {
                        <span class="fb-badge fb-status-active">
                            Đang bán
                        </span>
                    }
                    else
                    {
                        <span class="fb-badge fb-status-inactive">
                            Ngừng bán
                        </span>
                    }
                </div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mô tả</div>
                <div class="fb-detail-value">
                    @(string.IsNullOrWhiteSpace(Model.Description)
                        ? "Chưa có mô tả"
                        : Model.Description)
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-center mt-4">
                <a class="btn fb-btn-primary"
                   asp-controller="Products"
                   asp-action="Edit"
                   asp-route-productid="@Model.ProductId">
                    Sửa
                </a>

                <a class="btn fb-btn-outline"
                   asp-controller="Products"
                   asp-action="Index">
                    Quay lại
                </a>
            </div>
        </div>
    </div>
</section>