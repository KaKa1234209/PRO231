@model FastBite_PRO231.ViewModels.PromotionManagementFormViewModel

@{
    ViewData["Title"] = "Tạo khuyến mãi";
}

<section class="fbpromo-page">
    <div class="fbpromo-header">
        <div>
            <p>TẠO CHƯƠNG TRÌNH MỚI</p>

            <h1>Tạo khuyến mãi</h1>

            <span>
                Nhập thông tin giảm giá và chọn các sản phẩm được áp dụng.
            </span>
        </div>

        <a asp-controller="Promotions"
           asp-action="Index"
           class="fbpromo-reset-button">

            ← Quay lại danh sách
        </a>
    </div>

    <form asp-controller="Promotions"
          asp-action="Create"
          method="post"
          id="promotionForm">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger">
        </div>

        <div class="fbpromo-form-grid">
            <div class="fbpromo-form-left">

                <!-- THÔNG TIN KHUYẾN MÃI -->
                <section class="fbpromo-panel">
                    <div class="fbpromo-panel-heading">
                        <div>
                            <p>THÔNG TIN CHUNG</p>
                            <h2>Chương trình khuyến mãi</h2>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PromotionName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="PromotionName"
                               class="form-control"
                               placeholder="Ví dụ: Giảm 20% Combo Gà Rán" />

                        <span asp-validation-for="PromotionName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DiscountType"
                                   class="form-label fw-bold">
                            </label>

                            <select asp-for="DiscountType"
                                    class="form-select"
                                    id="discountType">

                                @if (Model.DiscountType == "Percent")
                                {
                                    <option value="Percent" selected>
                                        Giảm theo phần trăm (%)
                                    </option>
                                }
                                else
                                {
                                    <option value="Percent">
                                        Giảm theo phần trăm (%)
                                    </option>
                                }

                                @if (Model.DiscountType == "Fixed")
                                {
                                    <option value="Fixed" selected>
                                        Giảm số tiền cố định (VNĐ)
                                    </option>
                                }
                                else
                                {
                                    <option value="Fixed">
                                        Giảm số tiền cố định (VNĐ)
                                    </option>
                                }
                            </select>

                            <span asp-validation-for="DiscountType"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DiscountValue"
                                   class="form-label fw-bold">
                            </label>

                            <div class="fbpromo-value-input">
                                <input asp-for="DiscountValue"
                                       type="number"
                                       min="0.01"
                                       step="0.01"
                                       class="form-control"
                                       id="discountValue" />

                                <span id="discountUnit">
                                    %
                                </span>
                            </div>

                            <span asp-validation-for="DiscountValue"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Status"
                               class="form-label fw-bold">
                        </label>

                        <select asp-for="Status"
                                class="form-select"
                                id="promotionStatus">

                            @if (Model.Status == "Đang hoạt động")
                            {
                                <option value="Đang hoạt động" selected>
                                    Đang hoạt động
                                </option>
                            }
                            else
                            {
                                <option value="Đang hoạt động">
                                    Đang hoạt động
                                </option>
                            }

                            @if (Model.Status == "Tạm ngưng")
                            {
                                <option value="Tạm ngưng" selected>
                                    Tạm ngưng
                                </option>
                            }
                            else
                            {
                                <option value="Tạm ngưng">
                                    Tạm ngưng
                                </option>
                            }

                            @if (Model.Status == "Sắp diễn ra")
                            {
                                <option value="Sắp diễn ra" selected>
                                    Sắp diễn ra
                                </option>
                            }
                            else
                            {
                                <option value="Sắp diễn ra">
                                    Sắp diễn ra
                                </option>
                            }
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="fbpromo-form-hint">
                        Giảm theo phần trăm không được vượt quá 100%.
                        Giảm cố định được tính bằng VNĐ.
                    </div>
                </section>

                <!-- CHỌN SẢN PHẨM -->
                <section class="fbpromo-panel">
                    <div class="fbpromo-panel-heading">
                        <div>
                            <p>SẢN PHẨM ÁP DỤNG</p>
                            <h2>Chọn sản phẩm</h2>
                        </div>

                        <strong id="selectedCount"
                                class="fbpromo-selected-count">

                            0 sản phẩm đã chọn
                        </strong>
                    </div>

                    <div class="fbpromo-product-toolbar">
                        <input type="text"
                               id="productSearch"
                               class="form-control"
                               placeholder="Tìm tên sản phẩm hoặc danh mục..." />

                        <div class="fbpromo-select-actions">
                            <button type="button"
                                    id="selectAllButton"
                                    class="fbpromo-select-all-button">

                                Chọn tất cả đang hiển thị
                            </button>

                            <button type="button"
                                    id="clearAllButton"
                                    class="fbpromo-clear-button">

                                Bỏ chọn
                            </button>
                        </div>
                    </div>

                    <span asp-validation-for="SelectedProductIds"
                          class="text-danger d-block mb-3">
                    </span>

                    @if (Model.Products.Count == 0)
                    {
                        <div class="fbpromo-empty">
                            <div>🍔</div>

                            <h2>Chưa có sản phẩm</h2>

                            <p>
                                Hãy tạo sản phẩm trước khi tạo khuyến mãi.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="fbpromo-product-grid"
                             id="productGrid">

                            @foreach (var product in Model.Products)
                            {
                                var isSelected =
                                    Model.SelectedProductIds.Contains(
                                        product.ProductId);

                                <article class="fbpromo-product-option @(isSelected ? "selected" : "")"
                                         data-product-name="@product.ProductName.ToLower()"
                                         data-category-name="@product.CategoryName.ToLower()">

                                    <label for="product-@product.ProductId"
                                           class="fbpromo-product-label">

                                        <div class="fbpromo-product-image-wrap">
                                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                            {
                                                <img src="@product.ImageUrl"
                                                     alt="@product.ProductName"
                                                     class="fbpromo-product-image"
                                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />

                                                <div class="fbpromo-product-placeholder"
                                                     style="display:none;">
                                                    🍔
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="fbpromo-product-placeholder">
                                                    🍔
                                                </div>
                                            }
                                        </div>

                                        <div class="fbpromo-product-content">
                                            <div class="fbpromo-product-top">
                                                <strong>
                                                    @product.ProductName
                                                </strong>

                                                @if (product.Status)
                                                {
                                                    <span class="fbpromo-product-active">
                                                        Đang bán
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="fbpromo-product-inactive">
                                                        Tạm ẩn
                                                    </span>
                                                }
                                            </div>

                                            <span>
                                                @product.CategoryName
                                            </span>

                                            <strong class="fbpromo-product-price">
                                                @product.Price.ToString("N0")đ
                                            </strong>
                                        </div>

                                        <input type="checkbox"
                                               name="SelectedProductIds"
                                               value="@product.ProductId"
                                               id="product-@product.ProductId"
                                               class="form-check-input fbpromo-product-checkbox"
                                               checked="@isSelected" />
                                    </label>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>

            <!-- XEM TRƯỚC -->
            <aside class="fbpromo-form-right">
                <section class="fbpromo-preview-card">
                    <p>XEM TRƯỚC KHUYẾN MÃI</p>

                    <div class="fbpromo-preview-discount">
                        <span>GIẢM</span>

                        <strong id="discountPreview">
                            0%
                        </strong>
                    </div>

                    <h2 id="promotionNamePreview">
                        Chương trình khuyến mãi
                    </h2>

                    <div class="fbpromo-preview-info">
                        <span>Trạng thái</span>

                        <strong id="statusPreview">
                            @Model.Status
                        </strong>
                    </div>

                    <div class="fbpromo-preview-info">
                        <span>Sản phẩm áp dụng</span>

                        <strong id="productCountPreview">
                            0 sản phẩm
                        </strong>
                    </div>

                    <div class="fbpromo-preview-note">
                        Khuyến mãi sẽ được lưu sau khi bạn xác nhận
                        tạo chương trình.
                    </div>
                </section>

                <div class="fbpromo-submit-actions">
                    <button type="submit"
                            class="fbpromo-save-button"
                            onclick="return confirm('Xác nhận tạo chương trình khuyến mãi?')">

                        Lưu khuyến mãi
                    </button>

                    <a asp-controller="Promotions"
                       asp-action="Index"
                       class="fbpromo-reset-button">

                        Hủy
                    </a>
                </div>
            </aside>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const discountType =
                document.getElementById("discountType");

            const discountValue =
                document.getElementById("discountValue");

            const discountUnit =
                document.getElementById("discountUnit");

            const discountPreview =
                document.getElementById("discountPreview");

            const promotionName =
                document.getElementById("PromotionName");

            const promotionNamePreview =
                document.getElementById("promotionNamePreview");

            const promotionStatus =
                document.getElementById("promotionStatus");

            const statusPreview =
                document.getElementById("statusPreview");

            const selectedCount =
                document.getElementById("selectedCount");

            const productCountPreview =
                document.getElementById("productCountPreview");

            const productSearch =
                document.getElementById("productSearch");

            const selectAllButton =
                document.getElementById("selectAllButton");

            const clearAllButton =
                document.getElementById("clearAllButton");

            const productCards =
                document.querySelectorAll(".fbpromo-product-option");

            const checkboxes =
                document.querySelectorAll(".fbpromo-product-checkbox");

            const numberFormatter =
                new Intl.NumberFormat("vi-VN");

            function updateDiscountPreview() {
                const type =
                    discountType.value;

                const value =
                    Number(discountValue.value || 0);

                if (type === "Percent") {
                    discountUnit.textContent = "%";
                    discountPreview.textContent =
                        numberFormatter.format(value) + "%";
                }
                else {
                    discountUnit.textContent = "đ";
                    discountPreview.textContent =
                        numberFormatter.format(value) + "đ";
                }
            }

            function updatePromotionName() {
                const value =
                    promotionName.value.trim();

                promotionNamePreview.textContent =
                    value.length > 0
                        ? value
                        : "Chương trình khuyến mãi";
            }

            function updateStatus() {
                statusPreview.textContent =
                    promotionStatus.value;
            }

            function updateProductCount() {
                const checkedItems =
                    document.querySelectorAll(
                        ".fbpromo-product-checkbox:checked");

                const count =
                    checkedItems.length;

                selectedCount.textContent =
                    count + " sản phẩm đã chọn";

                productCountPreview.textContent =
                    count + " sản phẩm";

                productCards.forEach(function (card) {
                    const checkbox =
                        card.querySelector(
                            ".fbpromo-product-checkbox");

                    card.classList.toggle(
                        "selected",
                        checkbox.checked);
                });
            }

            function filterProducts() {
                const keyword =
                    productSearch.value
                        .trim()
                        .toLowerCase();

                productCards.forEach(function (card) {
                    const productName =
                        card.dataset.productName || "";

                    const categoryName =
                        card.dataset.categoryName || "";

                    const matched =
                        productName.includes(keyword) ||
                        categoryName.includes(keyword);

                    card.style.display =
                        matched ? "" : "none";
                });
            }

            discountType.addEventListener(
                "change",
                updateDiscountPreview);

            discountValue.addEventListener(
                "input",
                updateDiscountPreview);

            promotionName.addEventListener(
                "input",
                updatePromotionName);

            promotionStatus.addEventListener(
                "change",
                updateStatus);

            productSearch.addEventListener(
                "input",
                filterProducts);

            checkboxes.forEach(function (checkbox) {
                checkbox.addEventListener(
                    "change",
                    updateProductCount);
            });

            selectAllButton.addEventListener(
                "click",
                function () {
                    productCards.forEach(function (card) {
                        if (card.style.display !== "none") {
                            const checkbox =
                                card.querySelector(
                                    ".fbpromo-product-checkbox");

                            checkbox.checked = true;
                        }
                    });

                    updateProductCount();
                });

            clearAllButton.addEventListener(
                "click",
                function () {
                    checkboxes.forEach(function (checkbox) {
                        checkbox.checked = false;
                    });

                    updateProductCount();
                });

            updateDiscountPreview();
            updatePromotionName();
            updateStatus();
            updateProductCount();
        });
    </script>
}