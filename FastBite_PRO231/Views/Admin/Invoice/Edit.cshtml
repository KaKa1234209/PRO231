@model FastBite_PRO231.Models.Invoice

@{
    ViewData["Title"] = "Sửa hóa đơn";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Sửa hóa đơn #@Model.InvoiceId</h1>
                <p>Cập nhật nhân viên, phương thức và trạng thái thanh toán.</p>
            </div>

            <form asp-controller="Invoices"
                  asp-action="Edit"
                  asp-route-invoiceid="@Model.InvoiceId"
                  method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="InvoiceId" />
                <input type="hidden" asp-for="OrderId" />
                <input type="hidden" asp-for="InvoiceDate" />
                <input type="hidden" asp-for="TotalAmount" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="fb-detail-row mb-3">
                    <div class="fb-detail-label">Đơn hàng</div>
                    <div class="fb-detail-value">#@Model.OrderId</div>
                </div>

                <div class="fb-detail-row mb-3">
                    <div class="fb-detail-label">Tổng tiền</div>
                    <div class="fb-detail-value fb-price">@Model.TotalAmount.ToString("N0") VNĐ</div>
                </div>

                <div class="mb-3">
                    <label asp-for="EmployeeId" class="fb-form-label">Nhân viên lập hóa đơn</label>

                    <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeId" class="form-select fb-form-control">
                        <option value="">-- Chọn nhân viên --</option>
                    </select>

                    <span asp-validation-for="EmployeeId" class="text-danger fb-validation"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PaymentMethod" class="fb-form-label">Phương thức thanh toán</label>

                    <select asp-for="PaymentMethod" asp-items="ViewBag.PaymentMethodList" class="form-select fb-form-control"></select>

                    <span asp-validation-for="PaymentMethod" class="text-danger fb-validation"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Status" class="form-check-input" />
                    <label asp-for="Status" class="form-check-label">
                        Đã thanh toán
                    </label>
                </div>

                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="submit" class="btn fb-btn-primary">
                        Cập nhật
                    </button>

                    <a class="btn fb-btn-outline" asp-controller="Invoices" asp-action="Index">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}