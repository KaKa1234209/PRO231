@model Product

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Thêm sản phẩm</h1>
                <p>Tạo món ăn mới cho cửa hàng FastBite.</p>
            </div>

            <form asp-controller="Products" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3 fw-bold">
                </div>

                <div class="mb-3">
                    <label asp-for="ProductName" class="fb-form-label">
                        Tên sản phẩm
                    </label>

                    <input asp-for="ProductName"
                           class="form-control fb-form-control"
                           placeholder="Ví dụ: Burger bò phô mai" />

                    <span asp-validation-for="ProductName"
                          class="text-danger fb-validation">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="fb-form-label">
                        Danh mục
                    </label>

                    <select asp-for="CategoryId"
                            asp-items="ViewBag.CategoryId"
                            class="form-select fb-form-control">
                        <option value="">-- Chọn danh mục --</option>
                    </select>

                    <span asp-validation-for="CategoryId"
                          class="text-danger fb-validation">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="fb-form-label">
                        Giá bán
                    </label>

                    <input asp-for="Price"
                           class="form-control fb-form-control"
                           placeholder="Ví dụ: 45000" />

                    <span asp-validation-for="Price"
                          class="text-danger fb-validation">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Image" class="fb-form-label">
                        Đường dẫn hình ảnh
                    </label>

                    <input asp-for="Image"
                           class="form-control fb-form-control"
                           placeholder="Ví dụ: /images/burger.jpg hoặc link ảnh" />

                    <span asp-validation-for="Image"
                          class="text-danger fb-validation">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="fb-form-label">
                        Mô tả
                    </label>

                    <textarea asp-for="Description"
                              rows="4"
                              class="form-control fb-form-control"
                              placeholder="Nhập mô tả sản phẩm"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger fb-validation">
                    </span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Status" class="form-check-input" />

                    <label asp-for="Status" class="form-check-label fw-bold">
                        Đang bán
                    </label>
                </div>

                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="submit" class="btn fb-btn-primary">
                        Lưu sản phẩm
                    </button>

                    <a class="btn fb-btn-outline"
                       asp-controller="Products"
                       asp-action="Index">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}