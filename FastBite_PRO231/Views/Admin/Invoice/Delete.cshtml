@model FastBite_PRO231.Models.Invoice

@{
    ViewData["Title"] = "Xóa hóa đơn";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Xóa hóa đơn #@Model.InvoiceId</h1>
                <p>Bạn có chắc chắn muốn xóa hóa đơn này không?</p>
            </div>

            <div class="alert alert-danger fb-alert">
                Lưu ý: thao tác này sẽ xóa luôn chi tiết hóa đơn.
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Mã đơn hàng</div>
                <div class="fb-detail-value">#@Model.OrderId</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Khách hàng</div>
                <div class="fb-detail-value">@(Model.Order?.Customer?.User?.FullName ?? "Khách hàng")</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Nhân viên</div>
                <div class="fb-detail-value">@(Model.Employee?.User?.FullName ?? "Nhân viên")</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Ngày lập</div>
                <div class="fb-detail-value">@Model.InvoiceDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="fb-detail-row">
                <div class="fb-detail-label">Tổng tiền</div>
                <div class="fb-detail-value fb-price">@Model.TotalAmount.ToString("N0") VNĐ</div>
            </div>

            <form asp-controller="Invoices"
                  asp-action="Delete"
                  asp-route-invoiceid="@Model.InvoiceId"
                  method="post"
                  class="d-flex gap-2 justify-content-center mt-4">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn fb-btn-danger">
                    Xác nhận xóa
                </button>

                <a class="btn fb-btn-outline" asp-controller="Invoices" asp-action="Index">
                    Hủy
                </a>
            </form>
        </div>
    </div>
</section>