@model Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<section class="fb-admin-page">
    <div class="container">
        <div class="fb-form-card">
            <div class="fb-form-title">
                <h1>Thêm danh mục</h1>
                <p>Tạo danh mục mới cho sản phẩm thức ăn nhanh.</p>
            </div>

            <form asp-controller="Categories" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="mb-3">
                    <label asp-for="CategoryName" class="fb-form-label">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control fb-form-control" placeholder="Ví dụ: Burger" />
                    <span asp-validation-for="CategoryName" class="text-danger fb-validation"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="fb-form-label">Mô tả</label>
                    <textarea asp-for="Description" rows="4" class="form-control fb-form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger fb-validation"></span>
                </div>

                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="submit" class="btn fb-btn-primary">Lưu danh mục</button>

                    <a class="btn fb-btn-outline" asp-controller="Categories" asp-action="Index">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}