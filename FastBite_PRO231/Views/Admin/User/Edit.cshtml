@model FastBite_PRO231.ViewModels.UserManagementEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";

    var roleText = Model.RoleName switch
    {
        "Admin" => "Quản trị viên",
        "Employee" => "Nhân viên",
        "Customer" => "Khách hàng",
        _ => Model.RoleName
    };
}

<section class="fbuser-page">
    <div class="fbuser-header">
        <div>
            <p>CHỈNH SỬA TÀI KHOẢN</p>

            <h1>@Model.FullName</h1>

            <span>
                Cập nhật thông tin liên hệ và trạng thái tài khoản.
            </span>
        </div>

        <a asp-controller="Users"
           asp-action="Details"
           asp-route-id="@Model.UserId"
           class="fbuser-reset-button">

            ← Quay lại chi tiết
        </a>
    </div>

    <div class="fbuser-form-layout">
        <section class="fbuser-form-card">
            <div class="fbuser-panel-heading">
                <div>
                    <p>THÔNG TIN TÀI KHOẢN</p>
                    <h2>Cập nhật dữ liệu</h2>
                </div>

                <span class="fbuser-role fbuser-role-other">
                    @roleText
                </span>
            </div>

            <form asp-controller="Users"
                  asp-action="Edit"
                  asp-route-id="@Model.UserId"
                  method="post">

                @Html.AntiForgeryToken()

                <input asp-for="UserId"
                       type="hidden" />

                <input asp-for="RoleName"
                       type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="FullName"
                               class="form-control" />

                        <span asp-validation-for="FullName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UserName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="UserName"
                               class="form-control" />

                        <span asp-validation-for="UserName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Email"
                               type="email"
                               class="form-control" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Phone"
                               class="form-control" />

                        <span asp-validation-for="Phone"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Status"
                               class="form-label fw-bold">
                        </label>

                        <select asp-for="Status"
                                class="form-select">

                            @if (Model.Status == "Hoạt động")
                            {
                                <option value="Hoạt động" selected>
                                    Hoạt động
                                </option>
                            }
                            else
                            {
                                <option value="Hoạt động">
                                    Hoạt động
                                </option>
                            }

                            @if (Model.Status == "Ngừng hoạt động")
                            {
                                <option value="Ngừng hoạt động" selected>
                                    Ngừng hoạt động
                                </option>
                            }
                            else
                            {
                                <option value="Ngừng hoạt động">
                                    Ngừng hoạt động
                                </option>
                            }
                        </select>

                        <span asp-validation-for="Status"
                              class="text-danger">
                        </span>
                    </div>
                </div>

                <div class="fbuser-warning-box">
                    Vai trò <strong>@roleText</strong> không được thay đổi
                    tại trang này để tránh sai dữ liệu hồ sơ liên kết.
                </div>

                <div class="fbuser-form-actions">
                    <button type="submit"
                            class="fbuser-save-button"
                            onclick="return confirm('Xác nhận lưu thay đổi tài khoản?')">

                        Lưu thay đổi
                    </button>

                    <a asp-controller="Users"
                       asp-action="ResetPassword"
                       asp-route-id="@Model.UserId"
                       class="fbuser-password-button">

                        Đặt lại mật khẩu
                    </a>

                    <a asp-controller="Users"
                       asp-action="Details"
                       asp-route-id="@Model.UserId"
                       class="fbuser-reset-button">

                        Hủy
                    </a>
                </div>
            </form>
        </section>

        <aside class="fbuser-guide-card">
            <div class="fbuser-guide-icon">
                👤
            </div>

            <h2>@Model.FullName</h2>

            <div class="fbuser-guide-info">
                <span>Mã tài khoản</span>
                <strong>#@Model.UserId</strong>
            </div>

            <div class="fbuser-guide-info">
                <span>Vai trò</span>
                <strong>@roleText</strong>
            </div>

            <div class="fbuser-guide-info">
                <span>Trạng thái</span>
                <strong>@Model.Status</strong>
            </div>

            <p>
                Không thể tự khóa tài khoản Admin đang đăng nhập và không
                thể khóa Admin hoạt động cuối cùng.
            </p>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}